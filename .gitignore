# Large binary results (keep locally, do not track)
outputs/best_params.npz
outputs/multistart_lqr.npz
outputs/multistart_strings.npz
outputs/*.npz

# Keep report figures (generated by analysis.py, committed to git)
!outputs/fig_*.pdf
!outputs/fig_*.png

